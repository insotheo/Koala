struct Person{
	Name: byte*
	Age: uint
	
	static func new(name: byte*, age: uint): Person{
		let p: Person
		p.Name = name
		p.Age = age
		return p
	}
	
	func greet(){
		nprint("Hi! My name is %s! I'm %i years old!\n", this.Name, this.Age)
	}
	
	func addYear(){
		this.Age = this.Age + 1
	}
}

func main(){
	let john: Person = Person::new("John", 32)
	john.greet()
	john.addYear()
	john.greet()
}